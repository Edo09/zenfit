{
  "expo": {
    "name": "Hokage Coaching App",
    "slug": "habbito",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon/icon.png",
    "scheme": "hokagecoaching",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edo09.hokagecoaching",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/app-icon/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.edo09.hokagecoaching"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/app-icon/favicon.png",
      "lang": "es",
      "themeColor": "#000000"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/app-icon/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "node_modules/@expo-google-fonts/inter/400Regular/Inter_400Regular.ttf",
            "node_modules/@expo-google-fonts/inter/500Medium/Inter_500Medium.ttf",
            "node_modules/@expo-google-fonts/inter/600SemiBold/Inter_600SemiBold.ttf",
            "node_modules/@expo-google-fonts/inter/700Bold/Inter_700Bold.ttf",
            "node_modules/@expo-google-fonts/inter/800ExtraBold/Inter_800ExtraBold.ttf",
            "node_modules/@expo-google-fonts/inter/900Black/Inter_900Black.ttf",
            "./font/edo_sz/edosz.ttf"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "enableMinifyInReleaseBuilds": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos to attach meal pictures.",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take meal pictures.",
          "microphonePermission": false
        }
      ],
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      "./plugins/with-gradle-jvm-args.js",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab863b57-5202-4c06-8827-a0cd63b75311"
      }
    },
    "owner": "edo09"
  }
}
